rage.getItem('id_token');\n    }\n\n    login(idToken) {\n        localStorage.setItem('id_token', idToken);\n        window.location.assign('/');\n    }\n\n    logout() {\n        localStorage.removeItem('id_token');\n        window.location.assign('/');\n    }\n}\n\nexport default new AuthService();","/Users/ryanbelcher/Desktop/Random Projects/run_app/run_app/client/src/utils/mutations.js",[],[],"/Users/ryanbelcher/Desktop/Random Projects/run_app/run_app/client/src/components/Login.js",[],[],"/Users/ryanbelcher/Desktop/Random Projects/run_app/run_app/client/src/components/Content.js",["51"],[],"import React, { useContext } from 'react';\nimport Home from '../components/pages/Home';\nimport { HashRouter as Router, Routes, Route } from 'react-router-dom';\n\nfunction Content() {\n    return (\n        <div>\n            <Router>\n                <Routes>\n                    <Route\n                        path='/'\n                        element={<Home />}\n                    />\n                </Routes>\n            </Router>\n        </div>\n    );\n}\n\nexport default Content;","/Users/ryanbelcher/Desktop/Random Projects/run_app/run_app/client/src/components/pages/Home.js",["52"],[],{"ruleId":"53","severity":1,"message":"54","line":2,"column":8,"nodeType":"55","messageId":"56","endLine":2,"endColumn":18},{"ruleId":"57","severity":1,"message":"58","line":39,"column":1,"nodeType":"59","endLine":39,"endColumn":34},{"ruleId":"53","severity":1,"message":"60","line":1,"column":17,"nodeType":"55","messageId":"56","endLine":1,"endColumn":27},{"ruleId":"61","severity":1,"message":"62","line":10,"column":13,"nodeType":"63","endLine":10,"endColumn":46},"no-unused-vars","'SignupForm' is defined but never used.","Identifier","unusedVar","import/no-anonymous-default-export","Assign instance to a variable before exporting as module default","ExportDefaultDeclaration","'useContext' is defined but never used.","jsx-a11y/alt-text","img elements must have an alt prop, either wi